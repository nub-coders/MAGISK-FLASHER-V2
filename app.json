{
  "name": "Magisk Flasher Bot",
  "description": "A Telegram bot to patch boot.img with Magisk dynamically via GitHub releases",
  "repository": "https://github.com/nub-coders/MAGISK-FLASHER-V2",
  "keywords": [
    "telegram",
    "bot",
    "magisk",
    "flasher",
    "boot"
  ],
  "env": {
    "API_ID": {
      "description": "Your Telegram App API ID from https://my.telegram.org",
      "value": "2040",
      "required": true
    },
    "API_HASH": {
      "description": "Your Telegram App API Hash from https://my.telegram.org",
      "value": "b18441a1ff607e10a989891a5462e627",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Your Telegram Bot Token from @BotFather",
      "value": "",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "free"
    }
  },
  "stack": "container"
}